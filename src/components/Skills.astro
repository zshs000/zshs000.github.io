---
const skillGroups = [
  {
    title: '语言与基础',
    icon: 'J',
    skills: [
      { name: 'Java（集合/IO/多线程/JVM）', level: 90 },
      { name: 'Spring Boot / MyBatis', level: 90 },
      { name: 'Spring Cloud Alibaba', level: 85 },
      { name: 'MySQL（索引/事务/SQL优化）', level: 88 },
    ],
  },
  {
    title: '中间件与工程化',
    icon: 'M',
    skills: [
      { name: 'Redis（数据结构/缓存/原子操作）', level: 85 },
      { name: 'RocketMQ（异步解耦/削峰）', level: 80 },
      { name: 'Maven / Git / Docker', level: 85 },
      { name: 'Linux / CI/CD / 日志排查', level: 78 },
    ],
  },
  {
    title: 'AI 应用 & 其他',
    icon: 'AI',
    skills: [
      { name: 'Spring AI / RAG 链路设计', level: 82 },
      { name: 'AI 辅助研发（Codex/Claude Code）', level: 85 },
      { name: 'Vue3 / TypeScript', level: 75 },
      { name: 'Python / 自动化脚本', level: 72 },
    ],
  },
];
---

<section id="skills" style="padding-top: 2rem; padding-bottom: 3rem;">
  <div class="container">
    <div class="reveal">
      <h2 class="section-title">技能</h2>
      <p class="section-subtitle">// 我的技术栈与专业能力</p>
    </div>

    <div class="skills-grid">
      {skillGroups.map((group) => (
        <div class="skill-card reveal">
          <div class="skill-card-head">
            <span class="skill-icon">{group.icon}</span>
            <h3>{group.title}</h3>
          </div>
          <div class="skill-list">
            {group.skills.map((skill, i) => (
              <div class="skill-row">
                <div class="skill-meta">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-pct">{skill.level}<span class="pct-sign">%</span></span>
                </div>
                <div class="skill-bar">
                  <div class="skill-fill" style={`--w: ${skill.level}%; --delay: ${i * 0.3}s`}>
                    <div class="skill-shine"></div>
                  </div>
                  <div class="skill-segments">
                    {Array.from({length: 20}).map(() => <span class="seg"></span>)}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .skill-card {
    background: var(--bg-white);
    border: 2px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-hard);
    transition: all 0.3s ease;
  }

  .skill-card:hover {
    box-shadow: var(--shadow-accent);
    transform: translateY(-4px);
  }

  .skill-card-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .skill-icon {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-subtle);
    border: 2px solid var(--border);
    border-radius: 0.5rem;
    color: var(--accent);
  }

  .skill-card-head h3 {
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .skill-row {
    margin-bottom: 1.15rem;
  }
  .skill-row:last-child { margin-bottom: 0; }

  .skill-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .skill-name {
    font-size: 0.8rem;
    font-weight: 600;
  }

  .skill-pct {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }

  .pct-sign {
    font-size: 0.65rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* ── Loading bar ── */

  .skill-bar {
    position: relative;
    height: 20px;
    background: var(--bg-subtle);
    border: 1px solid #e4e4e7;
    border-radius: 4px;
    overflow: hidden;
  }

  .skill-fill {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    background: var(--text);
    border-radius: 3px;
    transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0s);
    z-index: 2;
  }

  .revealed .skill-fill {
    width: var(--w);
  }

  /* Shimmer effect */
  .skill-shine {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.15) 50%,
      transparent 100%
    );
    transform: translateX(-100%);
    animation: none;
  }

  .revealed .skill-shine {
    animation: shimmer 2s ease-in-out;
    animation-delay: calc(var(--delay, 0s) + 1s);
  }

  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }

  /* Grid segments overlay */
  .skill-segments {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    z-index: 3;
    pointer-events: none;
  }

  .seg {
    flex: 1;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }

  .seg:last-child {
    border-right: none;
  }

  @media (max-width: 768px) {
    .skills-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-fill { transition: none; }
    .skill-shine { animation: none; }
    .revealed .skill-fill { width: var(--w); }
  }
</style>
